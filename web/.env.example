# Workshop server — copy to .env for local dev
# Netlify: Site configuration → Environment variables (or: netlify env:import .env)

# Elastic Cloud — participants, sessions, doubts, stuck events, module progress, chat (semantic Q&A)
ELASTICSEARCH_URL=https://your-deployment.es.io:443
ELASTICSEARCH_API_KEY=your-api-key

# Optional — derived from ELASTICSEARCH_URL (.es. → .kb.) when omitted
# KIBANA_URL=https://your-deployment.kb.us-central1.gcp.elastic.cloud

# Facilitator login at /admin
ADMIN_PASSWORD=change-me-in-production

# Max API request body size (bytes)
BODY_SIZE_LIMIT=1048576
